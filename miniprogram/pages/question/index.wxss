.progress-block {
  margin-bottom: 30rpx;
}

.progress-row {
  display: flex;
  align-items: center;
  justify-content: space-between;
  margin-bottom: 18rpx;
}

.step {
  display: flex;
  align-items: center;
  justify-content: center;
  min-width: 124rpx;
  height: 52rpx;
  padding: 0 20rpx;
  border-radius: 999rpx;
  background: rgba(229, 139, 168, 0.14);
  border: 1rpx solid rgba(229, 139, 168, 0.28);
  color: #9d5974;
  font-size: 24rpx;
  letter-spacing: 0.12em;
}

.progress-copy {
  font-size: 24rpx;
  letter-spacing: 0.04em;
}

.progress-track {
  height: 14rpx;
  border-radius: 999rpx;
  background: rgba(229, 205, 216, 0.52);
  overflow: hidden;
  box-shadow: inset 0 0 0 1rpx rgba(214, 186, 197, 0.26);
}

.progress-fill {
  height: 100%;
  border-radius: inherit;
  background: linear-gradient(90deg, #e58ba8 0%, #ce7493 100%);
  box-shadow: 0 0 20rpx rgba(229, 139, 168, 0.34);
}

.hero {
  padding: 38rpx 34rpx 36rpx;
  margin-bottom: 26rpx;
  background: linear-gradient(180deg, rgba(255, 255, 255, 0.96) 0%, rgba(253, 240, 246, 0.84) 100%);
}

.title {
  font-size: 56rpx;
  line-height: 1.16;
  font-weight: 600;
  letter-spacing: -0.02em;
  color: #513d47;
}

.hint {
  margin-top: 18rpx;
  font-size: 28rpx;
  line-height: 1.68;
}

.options {
  display: flex;
  flex-direction: column;
  width: 100%;
}

.option {
  box-sizing: border-box;
  width: 100%;
  margin: 0;
  margin-bottom: 20rpx;
  padding: 30rpx 28rpx;
  border-radius: 32rpx;
  border: 1rpx solid rgba(214, 186, 197, 0.4);
  background: rgba(255, 255, 255, 0.74);
  color: #513d47;
  box-shadow: 0 12rpx 28rpx rgba(191, 160, 174, 0.1);
  overflow: hidden;
}

.option:last-child {
  margin-bottom: 0;
}

.option-inner {
  display: flex;
  align-items: flex-start;
  justify-content: space-between;
  width: 100%;
}

.option--hover {
  background: rgba(255, 249, 252, 0.92);
}

.option--active {
  border-color: rgba(229, 139, 168, 0.62);
  background: linear-gradient(135deg, rgba(255, 245, 249, 0.98) 0%, rgba(252, 235, 242, 0.98) 100%);
  box-shadow: 0 16rpx 34rpx rgba(229, 139, 168, 0.14);
}

.option-copy {
  flex: 1;
  min-width: 0;
  padding-right: 22rpx;
}

.option-title {
  font-size: 33rpx;
  font-weight: 600;
  line-height: 1.32;
  margin-bottom: 10rpx;
  color: #513d47;
}

.option-desc {
  font-size: 26rpx;
  line-height: 1.62;
}

.option-mark {
  flex-shrink: 0;
  width: 72rpx;
  height: 72rpx;
  margin-top: 4rpx;
  border-radius: 24rpx;
  display: flex;
  align-items: flex-start;
  justify-content: center;
  border: 1rpx solid rgba(214, 186, 197, 0.38);
  background: rgba(255, 249, 252, 0.88);
  font-size: 32rpx;
}

.option--active .option-title {
  color: #513d47;
}

.option--active .option-desc {
  color: rgba(109, 84, 94, 0.88);
}

.option--active .option-mark {
  background: linear-gradient(135deg, #e58ba8 0%, #ce7493 100%);
  color: #ffffff;
  box-shadow: 0 10rpx 22rpx rgba(229, 139, 168, 0.2);
}

.footnote {
  margin-top: 26rpx;
  padding: 24rpx 28rpx 28rpx;
}

.footnote-label {
  display: block;
  margin-bottom: 10rpx;
  color: #ce7493;
  font-size: 22rpx;
  letter-spacing: 0.14em;
}

.footnote-copy {
  display: block;
  line-height: 1.7;
  font-size: 26rpx;
}

.actions {
  display: flex;
  flex-direction: column;
  margin-top: 34rpx;
  padding-top: 34rpx;
}

.actions .action-primary {
  margin-top: 18rpx;
}

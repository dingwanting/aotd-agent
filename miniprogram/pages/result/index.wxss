.state,
.cover,
.track {
  margin-top: 18rpx;
  padding: 30rpx;
}

.state-title,
.cover-title {
  font-size: 42rpx;
  line-height: 1.3;
  font-weight: 600;
}

.state {
  display: flex;
  flex-direction: column;
}

.state-title {
  margin-top: 16rpx;
}

.state .muted,
.state .actions {
  margin-top: 16rpx;
}

.cover {
  margin-bottom: 24rpx;
  padding: 0;
  overflow: hidden;
  box-shadow: 0 18rpx 36rpx rgba(225, 156, 182, 0.18);
}

.cover-shell {
  padding: 34rpx 30rpx;
  background:
    radial-gradient(circle at 18% 18%, rgba(255, 243, 247, 0.96) 0%, rgba(255, 243, 247, 0) 34%),
    radial-gradient(circle at 86% 14%, rgba(243, 214, 225, 0.9) 0%, rgba(243, 214, 225, 0) 28%),
    linear-gradient(160deg, rgba(255, 249, 251, 0.98) 0%, rgba(250, 235, 241, 0.98) 100%);
}

.cover-mark {
  display: flex;
  align-items: center;
  justify-content: space-between;
  gap: 24rpx;
}

.cover-badge {
  padding: 8rpx 18rpx;
  border-radius: 999rpx;
  background: rgba(255, 255, 255, 0.68);
  color: #b86b88;
  font-size: 22rpx;
  letter-spacing: 0.18em;
}

.cover-body {
  margin-top: 42rpx;
}

.cover-title {
  font-size: 44rpx;
  font-weight: 600;
  line-height: 1.18;
  color: #4b3740;
}

.cover-subtitle {
  margin-top: 16rpx;
  font-size: 26rpx;
  line-height: 1.55;
}

.cover-meta {
  display: flex;
  flex-wrap: wrap;
  gap: 14rpx;
  margin-top: 26rpx;
}

.cover-chip {
  padding: 10rpx 18rpx;
  border-radius: 999rpx;
  background: rgba(255, 255, 255, 0.74);
  color: #926376;
  font-size: 22rpx;
}

.tracks {
  display: block;
}

.track-main {
  display: flex;
  align-items: flex-start;
  gap: 20rpx;
}

.track-rank {
  width: 58rpx;
  height: 58rpx;
  border-radius: 999rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  background: rgba(255, 241, 246, 0.92);
  color: #ce7493;
  font-size: 24rpx;
}

.track-copy { flex: 1; }

.track-title {
  font-size: 32rpx;
  font-weight: 600;
  color: #513d47;
}

.track-artist {
  margin-top: 8rpx;
  font-size: 26rpx;
  line-height: 1.55;
}

.track-keyword {
  margin-top: 14rpx;
  padding: 10rpx 14rpx;
  border-radius: 18rpx;
  background: rgba(255, 246, 249, 0.92);
  color: rgba(109, 84, 94, 0.82);
  font-size: 22rpx;
  line-height: 1.5;
}

.copy-button {
  flex: 1;
  min-height: 84rpx;
  border-radius: 999rpx;
  background: rgba(229, 139, 168, 0.12);
  color: #9d5974;
  border: 1rpx solid rgba(229, 139, 168, 0.32);
  font-size: 28rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  padding: 0 24rpx;
  box-sizing: border-box;
}

.copy-button--active {
  background: linear-gradient(135deg, rgba(255, 237, 244, 0.98) 0%, rgba(252, 229, 238, 0.98) 100%);
  border-color: rgba(229, 139, 168, 0.58);
  color: #8f536c;
}

.copy-button--single {
  width: 100%;
}

.track-actions {
  display: flex;
  gap: 16rpx;
  margin-top: 20rpx;
}

.play-button {
  flex: 1;
  min-height: 84rpx;
  border-radius: 999rpx;
  background: linear-gradient(135deg, #e58ba8 0%, #ce7493 100%);
  color: #ffffff;
  font-size: 28rpx;
  font-weight: 600;
  display: flex;
  align-items: center;
  justify-content: center;
  padding: 0 24rpx;
  box-sizing: border-box;
  box-shadow: 0 12rpx 24rpx rgba(229, 139, 168, 0.22);
}

.play-button--active {
  background: linear-gradient(135deg, #d87597 0%, #bf6988 100%);
}

.play-button--loading {
  background: linear-gradient(135deg, #e8a3b8 0%, #d989a5 100%);
}

.actions {
  display: flex;
  flex-direction: column;
  margin-top: 28rpx;
}

.actions .action-secondary {
  margin-top: 16rpx;
}

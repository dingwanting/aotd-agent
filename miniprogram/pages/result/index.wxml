<view class="page-shell">
  <view wx:if="{{loading}}" class="state card">
    <text class="eyebrow">AOTD</text>
    <view class="state-title">正在生成今晚歌单...</view>
    <view class="muted">我们正在根据你的三题答案整理今晚的情绪路线。</view>
  </view>

  <view wx:elif="{{errorMessage}}" class="state card">
    <text class="eyebrow">暂时失败</text>
    <view class="state-title">{{errorMessage}}</view>
    <view class="actions">
      <button class="action-primary" bindtap="handleRetry">重新生成</button>
      <button class="action-secondary" bindtap="handleRestart">回到问答</button>
    </view>
  </view>

  <block wx:else>
    <view class="cover card">
      <view class="cover-shell">
        <view class="cover-mark">
          <text class="eyebrow">Tonight Album</text>
          <text class="cover-badge">AOTD</text>
        </view>
        <view class="cover-body">
          <view class="cover-profile">
            <image wx:if="{{profileAvatarUrl}}" class="cover-avatar" src="{{profileAvatarUrl}}" mode="aspectFill"></image>
            <view class="cover-identity">
              <view class="cover-name">{{profileNickname}}</view>
              <view class="cover-caption">今晚由你亲自开场</view>
            </view>
          </view>
          <view class="cover-title">{{result.playlist.title}}</view>
          <view class="cover-subtitle muted">{{result.playlist.subtitle}}</view>
          <view class="cover-meta">
            <text class="cover-chip">{{result.playlist.tracks.length}} 首曲目</text>
            <text class="cover-chip">首推 {{result.playlist.tracks[0].song.title}}</text>
            <text class="cover-chip">先听再往下翻</text>
          </view>
        </view>
      </view>
    </view>

    <view class="tracks">
      <text class="eyebrow">Tonight Queue</text>
      <view
        wx:for="{{result.playlist.tracks}}"
        wx:key="rank"
        class="track card"
      >
        <view class="track-main">
          <view class="track-rank">#{{item.rank}}</view>
          <view class="track-copy">
            <view class="track-title-row">
              <view class="track-title">{{item.song.title}}</view>
              <view wx:if="{{item.moodTag}}" class="track-moodtag">{{item.moodTag}}</view>
            </view>
            <view class="track-artist muted">{{item.song.artist}}</view>
            <view class="track-keyword">搜索词：{{item.song.cliKeyword || item.song.title + ' ' + item.song.artist}}</view>
          </view>
        </view>
        <view class="track-actions">
          <view
            wx:if="{{supportsInlineAudio}}"
            class="play-button {{playingTrackIndex === index ? 'play-button--active' : ''}} {{loadingTrackIndex === index ? 'play-button--loading' : ''}}"
            data-index="{{index}}"
            bindtap="handlePlayTrack"
          >
            {{
              loadingTrackIndex === index
                ? '正在缓冲...'
                : playingTrackIndex === index
                  ? '暂停15秒试听'
                  : '15秒试听'
            }}
          </view>
          <view class="copy-button {{copiedTrackIndex === index ? 'copy-button--active' : ''}} {{supportsInlineAudio ? '' : 'copy-button--single'}}" data-index="{{index}}" bindtap="handleOpenNeteaseTrack">
            {{copiedTrackIndex === index ? '已打开播放页' : '去网易云听'}}
          </view>
        </view>
      </view>
    </view>

    <view class="actions">
      <button class="action-primary" loading="{{posterGenerating}}" disabled="{{posterGenerating}}" bindtap="handleGeneratePoster">生成 AOTD 报告</button>
      <button class="action-secondary" bindtap="handleRestart">重新回答</button>
    </view>

    <view wx:if="{{showPosterPreview}}" class="poster-preview-mask" catchtouchmove="noop">
      <view class="poster-preview-sheet card">
        <view class="poster-preview-head">
          <view class="poster-preview-title">AOTD 报告</view>
          <view class="poster-preview-close" bindtap="handleClosePosterPreview">关闭</view>
        </view>
        <image wx:if="{{posterImagePath}}" class="poster-preview-image" src="{{posterImagePath}}" mode="widthFix"></image>
        <view class="poster-preview-actions">
          <button class="action-primary" bindtap="handleSavePoster">保存到本地</button>
          <button class="action-secondary" bindtap="handleClosePosterPreview">先不保存</button>
        </view>
      </view>
    </view>

    <canvas id="aotdPosterCanvas" type="2d" class="poster-canvas"></canvas>
  </block>
</view>

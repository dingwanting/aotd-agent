<view class="page-shell">
  <view wx:if="{{loading}}" class="state card">
    <text class="eyebrow">AOTD</text>
    <view class="state-title">正在生成今晚歌单...</view>
    <view class="muted">我们正在根据你的三题答案整理今晚的情绪路线。</view>
  </view>

  <view wx:elif="{{errorMessage}}" class="state card">
    <text class="eyebrow">暂时失败</text>
    <view class="state-title">{{errorMessage}}</view>
    <view class="actions">
      <button class="action-primary" bindtap="handleRetry">重新生成</button>
      <button class="action-secondary" bindtap="handleRestart">回到问答</button>
    </view>
  </view>

  <block wx:else>
    <view class="cover card">
      <view class="cover-shell">
        <view class="cover-mark">
          <text class="eyebrow">Tonight Album</text>
          <text class="cover-badge">AOTD</text>
        </view>
        <view class="cover-body">
          <view class="cover-title">{{result.playlist.title}}</view>
          <view class="cover-subtitle muted">{{result.playlist.subtitle}}</view>
          <view class="cover-meta">
            <text class="cover-chip">{{result.playlist.tracks.length}} 首曲目</text>
            <text class="cover-chip">首推 {{result.playlist.tracks[0].song.title}}</text>
            <text class="cover-chip">先听再往下翻</text>
          </view>
        </view>
      </view>
    </view>

    <view class="tracks">
      <text class="eyebrow">Tonight Queue</text>
      <view
        wx:for="{{result.playlist.tracks}}"
        wx:key="rank"
        class="track card"
      >
        <view class="track-main">
          <view class="track-rank">#{{item.rank}}</view>
          <view class="track-copy">
            <view class="track-title">{{item.song.title}}</view>
            <view class="track-artist muted">{{item.song.artist}}</view>
            <view class="track-keyword">搜索词：{{item.song.cliKeyword || item.song.title + ' ' + item.song.artist}}</view>
          </view>
        </view>
        <view class="track-actions">
          <view
            wx:if="{{supportsInlineAudio}}"
            class="play-button {{playingTrackIndex === index ? 'play-button--active' : ''}} {{loadingTrackIndex === index ? 'play-button--loading' : ''}}"
            data-index="{{index}}"
            bindtap="handlePlayTrack"
          >
            {{
              loadingTrackIndex === index
                ? '正在缓冲...'
                : playingTrackIndex === index
                  ? '暂停15秒试听'
                  : '15秒试听'
            }}
          </view>
          <view class="copy-button {{copiedTrackIndex === index ? 'copy-button--active' : ''}} {{supportsInlineAudio ? '' : 'copy-button--single'}}" data-index="{{index}}" bindtap="handleCopyTrack">
            {{copiedTrackIndex === index ? '已复制，去网易云粘贴' : '复制到网易云搜索'}}
          </view>
        </view>
      </view>
    </view>

    <view class="actions">
      <button class="action-secondary" bindtap="handleRestart">重新回答</button>
    </view>
  </block>
</view>

page {
  min-height: 100%;
  background:
    linear-gradient(180deg, #fffdfd 0%, #fff7fb 58%, #fdf0f6 100%);
  color: #4a3942;
  font-family: -apple-system, BlinkMacSystemFont, "PingFang SC", "Helvetica Neue", sans-serif;
}

.page-shell {
  min-height: 100%;
  box-sizing: border-box;
  display: flex;
  flex-direction: column;
  padding: 44rpx 28rpx 72rpx;
}

.eyebrow {
  margin-bottom: 16rpx;
  color: #ce7493;
  font-size: 22rpx;
  letter-spacing: 0.18em;
  text-transform: uppercase;
}

.card {
  border: 1rpx solid rgba(214, 186, 197, 0.44);
  border-radius: 32rpx;
  background: rgba(255, 255, 255, 0.82);
  box-shadow: 0 18rpx 40rpx rgba(191, 160, 174, 0.16);
  overflow: hidden;
}

.muted {
  color: rgba(109, 84, 94, 0.78);
}

.action-primary,
.action-secondary {
  display: flex;
  align-items: center;
  justify-content: center;
  width: 100%;
  height: 96rpx;
  border-radius: 999rpx;
  box-sizing: border-box;
  font-size: 30rpx;
  font-weight: 600;
}

.action-primary {
  background: linear-gradient(135deg, #e58ba8 0%, #ce7493 100%);
  color: #ffffff;
  box-shadow: 0 18rpx 36rpx rgba(229, 139, 168, 0.26);
}

.action-primary--disabled {
  background: rgba(229, 139, 168, 0.34);
  color: rgba(255, 255, 255, 0.88);
  box-shadow: none;
}

.action-secondary {
  border: 1rpx solid rgba(214, 186, 197, 0.44);
  background: rgba(255, 249, 252, 0.72);
  color: #59444f;
}
